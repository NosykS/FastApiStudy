# --- Налаштування безпеки (JWT) ---
# Згенеруйте секретний ключ командою: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- PostgreSQL (SQLAlchemy) ---
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=fastapi_study
DB_HOST=db
DB_PORT=5432

# URL для підключення (використовується в SQLAlchemy/Alembic)
# Для Docker: postgresql+asyncpg://postgres:password@db:5432/fastapi_study
# Для локального запуску: postgresql+asyncpg://postgres:password@localhost:5432/fastapi_study
DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname

# --- MongoDB (Motor) ---
# Для Docker: mongodb://mongodb_container:27017
# Для локального запуску: mongodb://localhost:27017
MONGO_URL=mongodb://mongodb_container:27017
MONGO_DB_NAME=todo_db

# --- Налаштування логування ---
LOG_LEVEL=INFO
LOG_FILE=api.log